<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.yourbro.agent</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/yourbro-agent</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <!-- Set these for production use:
        <key>YOURBRO_TOKEN</key>
        <string>yb_your_token</string>
        <key>YOURBRO_SERVER_URL</key>
        <string>https://yourbro.ai</string>
        -->
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/yourbro-agent.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/yourbro-agent.err</string>
</dict>
</plist>
